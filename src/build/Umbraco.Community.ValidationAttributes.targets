<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

    <PropertyGroup>
        <UmbracoCommunityValidationAttributesContentFilesPath>$(MSBuildThisFileDirectory)..\App_Plugins\Umbraco.Community.ValidationAttributes\**\*.*</UmbracoCommunityValidationAttributesContentFilesPath>
    </PropertyGroup>

    <Target Name="CopyUmbracoCommunityValidationAttributesAssets" BeforeTargets="Build">
        <ItemGroup>
            <UmbracoCommunityValidationAttributesContentFiles Include="$(UmbracoCommunityValidationAttributesContentFilesPath)" />
        </ItemGroup>
        <Message Text="Copying Umbraco.Community.ValidationAttributes files: $(UmbracoCommunityValidationAttributesContentFilesPath) - #@(UmbracoCommunityValidationAttributesContentFiles->Count()) files"  Importance="high" />
        <Copy
            SourceFiles="@(UmbracoCommunityValidationAttributesContentFiles)"
            DestinationFiles="@(UmbracoCommunityValidationAttributesContentFiles->'$(MSBuildProjectDirectory)\App_Plugins\Umbraco.Community.ValidationAttributes\%(RecursiveDir)%(Filename)%(Extension)')"
            SkipUnchangedFiles="true" />

    </Target>

    <Target Name="ClearUmbracoCommunityValidationAttributesAssets" BeforeTargets="Clean">
        <ItemGroup>
            <UmbracoCommunityValidationAttributesDir Include="$(MSBuildProjectDirectory)\App_Plugins\Umbraco.Community.ValidationAttributes\" />
        </ItemGroup>
        <Message Text="Clear old Umbraco.Community.ValidationAttributes data"  Importance="high" />
        <RemoveDir Directories="@(UmbracoCommunityValidationAttributesDir)"  />
    </Target>

</Project>
